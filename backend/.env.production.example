APP_ENV=production
ALLOWED_ORIGINS=https://skillbridge.app
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority&appName=SkillBridge
MONGO_DB=skillbridge
PUBLIC_APP_URL=https://skillbridge.app
PUBLIC_API_URL=https://api.skillbridge.app

OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOCAL_ZERO_SHOT_MODEL=MoritzLaurer/deberta-v3-base-zeroshot-v1.1-all-33
LOCAL_REWRITE_MODEL=google/flan-t5-small
LOCAL_MODEL_DEVICE=-1
LOCAL_MODEL_PREWARM=true

ADMIN_OWNER_EMAILS=owner@example.com
ADMIN_TEAM_EMAILS=admin@example.com

USER_AVATAR_UPLOAD_DIR=backend/data/uploads/avatars
