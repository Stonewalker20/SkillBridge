APP_ENV=staging
ALLOWED_ORIGINS=https://staging.skillbridge.app
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.example.mongodb.net/?retryWrites=true&w=majority&appName=SkillBridge
MONGO_DB=skillbridge_staging
PUBLIC_APP_URL=https://staging.skillbridge.app
PUBLIC_API_URL=https://api-staging.skillbridge.app
PASSWORD_RESET_TOKEN_TTL_MINUTES=60

OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID=
STRIPE_PRICE_ID_STARTER=price_replace_me_starter
STRIPE_PRICE_ID_PRO=price_replace_me_pro
STRIPE_PRICE_ID_ELITE=price_replace_me_elite
STRIPE_CURRENCY=usd
STRIPE_SUCCESS_URL=https://staging.skillbridge.app/app/account?checkout=success
STRIPE_CANCEL_URL=https://staging.skillbridge.app/app/account?checkout=cancelled
STRIPE_BILLING_PORTAL_RETURN_URL=https://staging.skillbridge.app/app/account

LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOCAL_ZERO_SHOT_MODEL=MoritzLaurer/deberta-v3-base-zeroshot-v1.1-all-33
LOCAL_REWRITE_MODEL=google/flan-t5-small
LOCAL_MODEL_DEVICE=-1
LOCAL_MODEL_PREWARM=true

ADMIN_OWNER_EMAILS=owner@example.com
ADMIN_TEAM_EMAILS=admin@example.com

# Storage mode: set to s3 for a staging bucket, or keep local for dev-only runs.
MEDIA_STORAGE_MODE=s3
MEDIA_S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
MEDIA_S3_BUCKET=skillbridge-media-staging
MEDIA_S3_REGION=auto
MEDIA_S3_ACCESS_KEY_ID=replace-me
MEDIA_S3_SECRET_ACCESS_KEY=replace-me
MEDIA_S3_PUBLIC_BASE_URL=https://media-staging.skillbridge.app
MEDIA_S3_KEY_PREFIX=avatars

USER_AVATAR_UPLOAD_DIR=backend/data/uploads/avatars
