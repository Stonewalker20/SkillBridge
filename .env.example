APP_ENV=development
ALLOWED_ORIGINS=http://localhost:5173
MONGO_URI=mongodb://localhost:27017
MONGO_DB=skillbridge
PUBLIC_APP_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8000

OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOCAL_ZERO_SHOT_MODEL=MoritzLaurer/deberta-v3-base-zeroshot-v1.1-all-33
LOCAL_REWRITE_MODEL=google/flan-t5-small
LOCAL_MODEL_DEVICE=-1
LOCAL_MODEL_PREWARM=true

ADMIN_OWNER_EMAILS=owner@example.com
ADMIN_TEAM_EMAILS=admin@example.com

# Storage mode: local for dev, s3 for S3/R2-compatible object storage.
MEDIA_STORAGE_MODE=local
MEDIA_S3_ENDPOINT_URL=
MEDIA_S3_BUCKET=
MEDIA_S3_REGION=
MEDIA_S3_ACCESS_KEY_ID=
MEDIA_S3_SECRET_ACCESS_KEY=
MEDIA_S3_PUBLIC_BASE_URL=
MEDIA_S3_KEY_PREFIX=avatars

USER_AVATAR_UPLOAD_DIR=backend/data/uploads/avatars
